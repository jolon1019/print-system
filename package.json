{
  "name": "hot-roll-print-management",
  "version": "1.0.0",
  "description": "热卷打印管理系统 - 集成打印服务器、打印机客户端和Python监控",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "print-server": "node print-server.js",
    "printer-client": "node printer-client.js",
    "python-monitor": "python python_monitor.py"
  },
  "keywords": [
    "print",
    "management",
    "electron",
    "hot-roll"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "express": "^4.22.1",
    "ws": "^8.18.3"
  },
  "build": {
    "appId": "com.hotroll.printmanagement",
    "productName": "热卷打印管理系统",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
